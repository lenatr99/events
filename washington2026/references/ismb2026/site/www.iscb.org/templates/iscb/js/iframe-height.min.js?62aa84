((window, document) => {
    window.iFrameHeight = (iframe) => {
        try {
            // ✅ Same-origin iframe: Access content directly
            const doc = iframe.contentDocument || iframe.contentWindow.document;
            const height = parseInt(doc.documentElement.scrollHeight || doc.body.scrollHeight, 10);
            iframe.style.height = `${height + 60}px`; // Apply height
        } catch (e) {
            // ❌ Cross-origin detected: Use postMessage()
            console.log("Cross-origin iframe detected, using postMessage()");

            // Listen for messages from the iframe
            window.addEventListener("message", (event) => {
                // Whitelist of allowed origins
				const allowedOrigins = [
					'https://apps.iscb.org',
					'https://apps-test.iscb.org',
					'https://transition.iscb.org'
				];
				// Security check
				if (!allowedOrigins.includes(event.origin)) return;
				const data = event.data || {};
				// Handle height updates (apps format)
				if (data.height) {
					const iframe = document.getElementById('blockrandom');
					if (iframe) {
						iframe.style.height = data.height + 'px';
					}
				}
				// Handle height updates (legacy transition format)
				if (data.type === 'iscb-wrapper-height' && data.height) {
					const iframe = document.getElementById(data.id || 'blockrandom');
					if (iframe) {
						iframe.style.height = (parseInt(data.height, 10) || 0) + 'px';
					}
				}
            }, false);
        }
    };
})(window, document);