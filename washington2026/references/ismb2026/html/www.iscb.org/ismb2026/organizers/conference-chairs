	<script>
		(function (){
			// Processing overlay
			const iframe = document.getElementById ('blockrandom');
			const overlay = document.getElementById ('iscb-viewport-loading');
			let hideTimer = null;
			let formSubmitted = false;
			
			function showOverlay () {
				if (!overlay) return;
				overlay.style.display = 'block';
				overlay.setAttribute ('aria-hidden', 'false');
				//lock scroll so the user doesn’t “scroll past” the overlay
				const sw = window.innerWidth - document.documentElement.clientWidth;
				document.documentElement.style.overflow = 'hidden';
				document.body.style.overflow = 'hidden';
				document.body.style.cursor = 'wait';
				if (sw > 0) document.documentElement.style.paddingRight = sw + 'px';
				clearTimeout (hideTimer);
				hideTimer = setTimeout (hideOverlay, 25000); //failsafe
			}

			// Hide the processing overlay
			function hideOverlay () {
				if (!overlay) return;
				overlay.style.display = 'none';
				overlay.setAttribute ('aria-hidden', 'true');
				document.documentElement.style.overflow = '';
				document.body.style.overflow = '';
				document.body.style.cursor = '';
				document.documentElement.style.paddingRight = '';
				clearTimeout (hideTimer);
				hideTimer = null;
				formSubmitted = false;
			}
			
			// Check source
			function originAllowed(origin){
				try {
					const u = new URL(origin);
					return u.hostname.endsWith('.iscb.org') || u.hostname === 'iscb.org';
				} catch { 
					return false; 
				}
			}
			
			// Add the listener
			window.addEventListener ('message', (e) => {
				if (!originAllowed(e.origin)) return;
				const d = e.data || {};
				
				// Height updates from transition.iscb.org
				if (d.type === 'iscb-wrapper-height' && typeof d.height === 'number') {
					const f = document.getElementById (d.id || 'blockrandom');
					if (f) {
						f.style.height = d.height + 'px';
						if (!formSubmitted) {
							hideOverlay ();
						}
					}
				}
			
				// Height updates from apps.iscb.org
				if (typeof d.height === 'number' && !d.type) {
					iframe.style.height = d.height + 'px';
					if (!formSubmitted) {
						hideOverlay();
					}
				}
				
				// Explicit height set requests
				if (d.type === 'iscb-wrapper-cmd' && d.action === 'setHeight' && typeof d.height === 'number') {
					iframe.style.height = d.height + 'px';
				}
				
				// Explicit loading commands (form submissions from transition.iscb.org)
				if (d.type === 'iscb-wrapper-cmd' && d.action === 'loading') {
					if (d.state === 'start') {
						formSubmitted = true;
						showOverlay();
					}
					if (d.state === 'stop') {
						formSubmitted = false;
						hideOverlay();
					}
				}
				
				// Scroll requests
				if (d.type === 'iscb-wrapper-cmd' && d.action === 'scrollParentTo') {
					window.scrollTo ({ top: 0, behavior: 'smooth' }); //scroll full J5 page
				}
				
				// Handshake
				if (d.type === 'iscb-hello-from-child') {
					e.source?.postMessage ({ type: 'iscb-parent-ready' }, e.origin);
				}
				
				// Anchor links
				if (d.type === 'iscb-wrapper-cmd' && d.action === 'scrollParentToChildOffset' && typeof d.offset === 'number') {
					const f = document.getElementById ('blockrandom');
					if (!f) return;
					const iframeTop = f.getBoundingClientRect ().top + window.scrollY;
					const HEADER = 120; // adjust for your fixed site header height
					window.scrollTo ({ top: iframeTop + d.offset - HEADER, behavior: 'smooth' });
				}
			}, false);
			
			// Post load functions
			function ready (){
				if (!iframe) return;
				// Show overlay immediately
				showOverlay ();
				let isInitialLoad = true;
				iframe.addEventListener ('load', () => {
					// Hide overlay on load ONLY if form wasn't submitted
					if (!formSubmitted) {
						hideOverlay ();
					} else {
						// Form was submitted, wait for new page to fully load
						formSubmitted = false;
						setTimeout (hideOverlay, 500);
					}
					window.scrollTo ({ top: 0, behavior: 'smooth' });
					if (isInitialLoad) {
						isInitialLoad = false;
						try {
							iframe.contentWindow.location.reload ();
						} catch (e) {
							const currentSrc = iframe.src;
							const separator = currentSrc.includes ('?') ? '&' : '?';
							iframe.src = currentSrc + separator + '_t=' + Date.now();
						}
					}
				});
			}
			(document.readyState === 'loading') ? document.addEventListener('DOMContentLoaded', ready) : ready();
		})();
	</script> 
